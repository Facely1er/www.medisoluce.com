# Production Environment Variables
# Copy this to .env.production.local and fill in your production values

# Supabase Production Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_production_anon_key

# Analytics & Monitoring
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_SENTRY_DSN=https://xxxx@sentry.io/xxxxx

# Application Configuration
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=production

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_PWA=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# API Configuration
VITE_API_BASE_URL=https://api.medisoluce.com
VITE_API_TIMEOUT=30000

# Security
VITE_CSP_REPORT_URI=https://api.medisoluce.com/csp-report
VITE_ENABLE_SECURITY_HEADERS=true

# Performance
VITE_PERFORMANCE_SAMPLE_RATE=0.1