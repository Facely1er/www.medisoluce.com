# MediSoluce Healthcare Compliance Platform - Production Environment Variables
# Copy this file to .env.production.local and fill in your actual values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Analytics and Monitoring
VITE_GA_TRACKING_ID=your-google-analytics-id
VITE_SENTRY_DSN=your-sentry-dsn

# Optional: Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Optional: API Endpoints
VITE_API_BASE_URL=https://api.medisoluce.com
VITE_CDN_URL=https://cdn.medisoluce.com

# Optional: Third-party Services
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-key
VITE_SENDGRID_API_KEY=your-sendgrid-key

# Development/Testing
NODE_ENV=production
VITE_APP_VERSION=1.0.0
VITE_BUILD_DATE=2024-01-01T00:00:00Z