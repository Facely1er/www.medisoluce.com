# MediSoluce Healthcare Compliance Platform - Environment Variables

# Application Configuration
VITE_APP_VERSION=1.0.0

# Supabase Configuration (Optional - for cloud sync functionality)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Analytics Configuration (Optional)
VITE_GA_TRACKING_ID=your_google_analytics_id_here

# Sentry Error Tracking (Optional - for production monitoring)
VITE_SENTRY_DSN=your_sentry_dsn_here

# Build Configuration
NODE_ENV=production

# Security Configuration
VITE_CSP_REPORT_URI=/csp-report

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false
VITE_ENABLE_CLOUD_SYNC=false