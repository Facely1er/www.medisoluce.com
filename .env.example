 
# MediSoluce Environment Variables
# Copy this file to .env.local for local development

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Analytics
VITE_GA_TRACKING_ID=your_google_analytics_tracking_id

# Sentry Error Tracking (Optional)
VITE_SENTRY_DSN=your_sentry_dsn

# Application Version
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_PWA=true

# Security Configuration
VITE_CSP_REPORT_URI=/api/csp-report
VITE_ENABLE_SECURITY_HEADERS=true

# Performance Monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_PERFORMANCE_SAMPLE_RATE=0.1

# API Configuration (if needed)
VITE_API_BASE_URL=https://api.medisoluce.com
VITE_API_TIMEOUT=30000

# Environment
VITE_ENVIRONMENT=production
 
# MediSoluce Healthcare Compliance Platform - Environment Variables
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration (Required)
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Analytics (Optional)
VITE_GA_TRACKING_ID=your_google_analytics_tracking_id

# Error Tracking (Optional)
VITE_SENTRY_DSN=your_sentry_dsn_here

# Application Configuration
VITE_APP_NAME=MediSoluce
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=production

# Security Configuration
VITE_ENABLE_SECURITY_SCANNING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_ENABLE_HEALTH_CHECKS=true

# Feature Flags
VITE_ENABLE_PWA=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=false

# Development Configuration (for local development only)
VITE_DEBUG_MODE=false
VITE_MOCK_DATA=false
 