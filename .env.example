# Environment Configuration for MediSoluce Healthcare Compliance Platform

# Supabase Configuration (Required for database features)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Analytics Configuration (Optional)
VITE_GA_TRACKING_ID=your_google_analytics_id_here

# Error Monitoring (Optional - Production)
VITE_SENTRY_DSN=your_sentry_dsn_here

# Application Configuration
VITE_APP_VERSION=1.0.0
VITE_APP_NAME=MediSoluce

# Build Configuration
NODE_ENV=production
VERCEL_ENV=production

# Security Configuration (Production)
VITE_ENABLE_HTTPS=true
VITE_SECURE_COOKIES=true

# Performance Configuration
VITE_ENABLE_ANALYTICS=true
VITE_PERFORMANCE_MONITORING=true

# Feature Flags
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_MULTI_LANGUAGE=true
VITE_ENABLE_PWA=true

# Healthcare Compliance Features
VITE_ENABLE_HIPAA_ASSESSMENT=true
VITE_ENABLE_DEPENDENCY_MAPPING=true
VITE_ENABLE_BUSINESS_IMPACT=true
VITE_ENABLE_CONTINUITY_PLANNING=true
VITE_ENABLE_RANSOMWARE_PROTECTION=true
VITE_ENABLE_TRAINING_MODULES=true
VITE_ENABLE_RESOURCE_TOOLKIT=true

# Data Storage (Privacy-by-design)
VITE_LOCAL_STORAGE_ENCRYPTION=true
VITE_DATA_RETENTION_DAYS=2555  # 7 years for healthcare compliance

# Contact Information
VITE_SUPPORT_EMAIL=support@medisoluce.com
VITE_CONTACT_PHONE=+1-555-123-4567
VITE_ORGANIZATION_NAME=MediSoluce by ERMITS