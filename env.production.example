# MediSoluce Production Environment Variables
# Copy this file to .env.production and fill in your actual values
# DO NOT commit .env.production to version control

# Supabase Configuration
# Get these values from your Supabase project dashboard:
# https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Required: Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Required: Your Supabase anonymous/public key (safe to expose in client-side code)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key (only needed for admin operations)
# WARNING: Never expose this in client-side code. Only use server-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Application Configuration
NODE_ENV=production

# Build Information (automatically set during build)
# __APP_VERSION__ is set from package.json
# __BUILD_DATE__ is set automatically
# __COMMIT_HASH__ is set from CI/CD environment

# Stripe Configuration (for payment processing)
# Get your publishable key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here

# Application Base URL (for policy links in Stripe Checkout)
# Set this to your production domain
VITE_APP_BASE_URL=https://www.medisoluce.com

# Backend API URL (for creating Stripe Checkout Sessions)
# For Vercel/Netlify: Leave empty or set to /api (uses same domain)
# For custom backend: Set to your backend URL
VITE_API_URL=

# Stripe Secret Key (BACKEND ONLY - Set in deployment platform)
# Vercel: Project Settings > Environment Variables > Add STRIPE_SECRET_KEY
# Netlify: Site Settings > Environment Variables > Add STRIPE_SECRET_KEY
# Get from: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_your_secret_key_here

# Stripe Webhook Secret (BACKEND ONLY - Set in deployment platform)
# Get from: Stripe Dashboard > Developers > Webhooks > Your webhook > Signing secret
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

