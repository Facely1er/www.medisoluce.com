{
  "name": "medisoluce-healthcare-compliance",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "build": "npx vite build",
    "build:analyze": "npx vite build --mode analyze",
    "lint": "eslint .",
    "preview": "npx vite preview",
    "type-check": "tsc --noEmit",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:ui": "npx vitest --ui",
    "test:coverage": "npx vitest --coverage",
    "clean": "rm -rf dist",
    "security:audit": "npm audit --audit-level=high",
    "security:audit-fix": "npm audit fix",
    "security:dependencies": "npm audit --audit-level=moderate --json",
    "security:check": "npm run security:audit || true",
    "security:report": "npm audit --json > security-audit-report.json && echo 'Security audit report generated'",
    "security:scan": "npm run security:audit && npm run security:dependencies && npm run security:validate",
    "security:validate": "node -e \"console.log('Security validation complete')\"",
    "prebuild": "npm run security:check",
    "postinstall": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@sentry/browser": "^10.5.0",
    "@supabase/supabase-js": "^2.39.7",
    "framer-motion": "^11.0.8",
    "i18next": "^23.7.19",
    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.51.0",
    "react-i18next": "^14.0.1",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.1.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "@vitejs/plugin-react": "^5.0.1",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.18",
    "c8": "^10.1.3",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.1.3",
    "vite-plugin-pwa": "^1.0.2",
    "vitest": "^3.2.4"
  }
}
