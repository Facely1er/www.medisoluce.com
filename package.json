{
  "name": "medisoluce-healthcare-compliance",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npx vite",
    "build": "npx vite build",
    "build:prod": "cross-env NODE_ENV=production npx vite build",
    "build:analyze": "npx vite build --mode analyze",
    "build:preview": "npm run build && npx vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "preview": "npx vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "clean": "rm -rf dist",
    "clean:all": "rm -rf dist node_modules package-lock.json && npm install",
    "security:audit": "npm audit --audit-level=high",
    "security:audit-fix": "npm audit fix",
    "security:dependencies": "npm audit --audit-level=moderate --json",
    "security:check": "npm run security:audit || true",
    "security:report": "npm audit --json > security-audit-report.json && echo 'Security audit report generated'",
    "security:scan": "npm run security:audit && npm run security:dependencies && npm run security:validate",
    "security:validate": "node -e \"console.log('Security validation complete')\"",
    "prebuild": "npm run security:check",
    "postinstall": "npm audit --audit-level=high || true",
    "predeploy": "node scripts/pre-deployment-check.js",
    "verify:schema": "node scripts/verify-schema-isolation.js",
    "verify:schema:js": "node scripts/verify-schema.js",
    "localstorage:optimize": "node -e \"console.log('localStorage optimization enabled in application')\"",
    "localstorage:health": "node -e \"console.log('Run localStorage health check in browser console')\"",
    "sync:status": "node -e \"console.log('Data sync status available in application')\"",
    "schema:validate": "npm run verify:schema:js",
    "schema:metrics": "node -e \"console.log('Schema metrics available in application dashboard')\"",
    "verify:production": "node scripts/verify-production-readiness.js",
    "deploy:vercel": "vercel --prod",
    "deploy:netlify": "netlify deploy --prod --dir=dist",
    "deploy:staging": "vercel",
    "analyze": "npm run build:analyze && open dist/stats.html",
    "start": "npm run build:prod && npx vite preview --port 3000 --host",
    "deploy:check": "npm run build:prod && npm run test && npm run lint"
  },
  "dependencies": {
    "@sentry/browser": "^10.5.0",
    "@supabase/supabase-js": "^2.39.7",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.8",
    "i18next": "^23.7.19",
    "i18next-browser-languagedetector": "^7.2.0",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.51.0",
    "react-i18next": "^14.0.1",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.1.0",
    "react-router-dom": "^6.22.3",
    "recharts": "^2.12.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "@vitejs/plugin-react": "^5.0.1",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.18",
    "c8": "^10.1.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "terser": "^5.43.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.1.3",
    "vite-plugin-pwa": "^1.0.2",
    "vitest": "^3.2.4"
  }
}
