# MediSoluce Development Environment Variables
# Copy this file to .env.local for local development
# DO NOT commit .env.local to version control

# Supabase Configuration
# Get these values from your Supabase project dashboard:
# https://app.supabase.com/project/YOUR_PROJECT/settings/api

# Required: Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Required: Your Supabase anonymous/public key (safe to expose in client-side code)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key (only needed for admin operations)
# WARNING: Never expose this in client-side code. Only use server-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Application Configuration
NODE_ENV=development

# Stripe Configuration (for payment processing)
# Get your publishable key from: https://dashboard.stripe.com/apikeys
# WARNING: Never use your secret key in frontend code - only use it in backend API
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Application Base URL (for policy links in Stripe Checkout)
# In production, set this to your actual domain (e.g., https://www.medisoluce.com)
VITE_APP_BASE_URL=http://localhost:5173

# Backend API URL (for creating Stripe Checkout Sessions)
# Your backend API endpoint that securely creates checkout sessions
VITE_API_URL=http://localhost:3000/api

